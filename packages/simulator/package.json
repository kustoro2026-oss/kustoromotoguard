{
  "name": "@kustoro/simulator",
  "version": "2.0.0",
  "private": true,
  "description": "Realistic motorcycle fleet GPS simulator with smooth route interpolation",
  "scripts": {
    "dev": "tsx src/index.ts",
    "dev:fast": "SIM_SPEED=3 tsx src/index.ts",
    "dev:slow": "SIM_SPEED=0.5 tsx src/index.ts",
    "dev:3": "SIM_DEVICES=3 tsx src/index.ts",
    "dev:8": "SIM_DEVICES=8 tsx src/index.ts",
    "dev:verbose": "SIM_VERBOSE=1 tsx src/index.ts",
    "dev:quiet": "SIM_QUIET=1 tsx src/index.ts"
  },
  "dependencies": {
    "mqtt": "^5.10.0",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.7.0",
    "@types/uuid": "^10.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
