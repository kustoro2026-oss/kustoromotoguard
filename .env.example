# ═══════════════════════════════════════════
#  KustoroMotoGuard — Environment Variables
# ═══════════════════════════════════════════
#
#  Copy this file to .env and adjust as needed:
#    cp .env.example .env
#

# ─── Local Development (with docker compose) ───
# Run: docker compose up -d    (starts Mosquitto + PostgreSQL + Redis + MinIO)
# Then: npm run dev            (starts backend + simulator + frontend)

NODE_ENV=development
PORT=3000

# MQTT (Mosquitto in Docker)
MQTT_BROKER_URL=mqtt://localhost:1883

# PostgreSQL (Docker)
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=kustoro
DATABASE_USER=kustoro
DATABASE_PASSWORD=kustoro123

# Redis (Docker)
REDIS_HOST=localhost
REDIS_PORT=6379

# MinIO (Docker)
STORAGE_ENDPOINT=localhost
STORAGE_PORT=9000
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin
STORAGE_BUCKET=kustoro-audio
STORAGE_USE_SSL=false

# JWT
JWT_SECRET=dev-secret-change-me
JWT_EXPIRES_IN=7d

# ─── Production (Railway) ──────────────────
# Railway auto-provides DATABASE_URL and REDIS_URL via plugins.
# Uncomment and set these only if NOT using Railway plugins:

# DATABASE_URL=postgres://...  (Railway sets this automatically)
# REDIS_URL=redis://...        (Railway sets this automatically)

# MQTT Broker (e.g., HiveMQ Cloud free tier)
# MQTT_BROKER_URL=mqtts://your-cluster.hivemq.cloud:8883
# MQTT_USERNAME=your-username
# MQTT_PASSWORD=your-password

# Storage (Cloudflare R2 - S3 compatible)
# STORAGE_ENDPOINT=xxx.r2.cloudflarestorage.com
# STORAGE_ACCESS_KEY=your-r2-access-key
# STORAGE_SECRET_KEY=your-r2-secret-key
# STORAGE_BUCKET=kustoro-audio
# STORAGE_USE_SSL=true

# Security
# JWT_SECRET=generate-a-random-string-here
# JWT_EXPIRES_IN=7d

# ─── Simulator Settings ────────────────────
# Control the virtual motorcycle fleet simulation behavior.
# These env vars are read by packages/simulator

# Number of virtual devices (1-8)
# SIM_DEVICES=5

# Location update interval in milliseconds (default 1000)
# SIM_INTERVAL=500

# Global speed multiplier — 1.0 = real-time, 2.0 = double speed, 0.5 = half speed
# SIM_SPEED=1.0

# Random alert chance per cycle (0-1, default 0.15)
# SIM_ALERT_CHANCE=0.3

# Show detailed command logs
# SIM_VERBOSE=1

# Suppress all logs except errors
# SIM_QUIET=1
