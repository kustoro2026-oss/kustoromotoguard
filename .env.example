# ─── Development (Local Docker) ───
# PORT=3000
# NODE_ENV=development
# MQTT_BROKER_URL=mqtt://localhost:1883
# DATABASE_HOST=localhost
# DATABASE_PORT=5432
# DATABASE_NAME=kustoro
# DATABASE_USER=kustoro
# DATABASE_PASSWORD=kustoro123
# REDIS_HOST=localhost
# REDIS_PORT=6379
# STORAGE_ENDPOINT=localhost
# STORAGE_PORT=9000
# STORAGE_ACCESS_KEY=minioadmin
# STORAGE_SECRET_KEY=minioadmin
# STORAGE_BUCKET=kustoro-audio
# STORAGE_USE_SSL=false
# JWT_SECRET=dev-secret
# JWT_EXPIRES_IN=7d

# ─── Production (Railway) ───
# Railway auto-provides DATABASE_URL and REDIS_URL via plugins.
# You only need to set these manually:

# MQTT Broker (HiveMQ Cloud free tier)
MQTT_BROKER_URL=mqtts://your-cluster.hivemq.cloud:8883
MQTT_USERNAME=your-username
MQTT_PASSWORD=your-password

# Storage (Cloudflare R2 - S3 compatible)
STORAGE_ENDPOINT=xxx.r2.cloudflarestorage.com
STORAGE_ACCESS_KEY=your-r2-access-key
STORAGE_SECRET_KEY=your-r2-secret-key
STORAGE_BUCKET=kustoro-audio
STORAGE_USE_SSL=true

# Security
JWT_SECRET=generate-a-random-string-here
JWT_EXPIRES_IN=7d
